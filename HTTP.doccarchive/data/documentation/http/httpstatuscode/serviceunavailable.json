{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"serviceUnavailable"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Common causes are a server that is down for maintenance or that is overloaded."},{"type":"text","text":" "},{"type":"text","text":"Note that together with this response, a user-friendly page explaining the problem should be sent."},{"type":"text","text":" "},{"type":"text","text":"This response should be used for temporary conditions and the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Retry-After"}]},{"type":"text","text":" HTTP header should,"},{"type":"text","text":" "},{"type":"text","text":"if possible, contain the estimated time before the recovery of the service."},{"type":"text","text":" "},{"type":"text","text":"The webmaster must also take care about the caching-related headers that are sent along with this response,"},{"type":"text","text":" "},{"type":"text","text":"as these temporary condition responses should usually not be cached."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/http\/httpstatuscode\/serviceunavailable"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/HTTP\/documentation\/HTTP\/HTTPStatusCode\/serviceUnavailable","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"The server is not ready to handle the request."}],"kind":"symbol","metadata":{"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"serviceUnavailable"}],"title":"HTTPStatusCode.serviceUnavailable","roleHeading":"Case","role":"symbol","symbolKind":"case","externalID":"s:4HTTP14HTTPStatusCodeO18serviceUnavailableyA2CmF","modules":[{"name":"HTTP"}]},"hierarchy":{"paths":[["doc:\/\/HTTP\/documentation\/HTTP","doc:\/\/HTTP\/documentation\/HTTP\/HTTPStatusCode"]]},"references":{"doc://HTTP/documentation/HTTP/HTTPStatusCode/serviceUnavailable":{"role":"symbol","title":"HTTPStatusCode.serviceUnavailable","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"serviceUnavailable"}],"abstract":[{"type":"text","text":"The server is not ready to handle the request."}],"identifier":"doc:\/\/HTTP\/documentation\/HTTP\/HTTPStatusCode\/serviceUnavailable","kind":"symbol","type":"topic","url":"\/documentation\/http\/httpstatuscode\/serviceunavailable"},"doc://HTTP/documentation/HTTP":{"role":"collection","title":"HTTP","abstract":[],"identifier":"doc:\/\/HTTP\/documentation\/HTTP","kind":"symbol","type":"topic","url":"\/documentation\/http"},"doc://HTTP/documentation/HTTP/HTTPStatusCode":{"role":"symbol","title":"HTTPStatusCode","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"HTTPStatusCode"}],"abstract":[{"type":"text","text":"Status codes defined to be used by HTTP."}],"identifier":"doc:\/\/HTTP\/documentation\/HTTP\/HTTPStatusCode","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"HTTPStatusCode"}],"url":"\/documentation\/http\/httpstatuscode"}}}